//- Shared poem-content mixin — included by poem.pug (fragment) and poem-page.pug (full page).
//- Do NOT add a <script> block here; the embedded-player loader lives in public/poetic.js.

//- JavaScript helper: slugify text (mirrors slugify.js)
- function slugify(text) {
-   text = text.toLowerCase().trim()
-   text = text.replace(/[^a-z0-9 -]/g, '')
-   text = text.replace(/ +/g, '-')
-   return text;
- }

//- Compute effective postscript preview settings from a postscript item's params.
//- preview defaults to true unless params.preview is the string "false".
//- previewLines defaults to 5 unless params['preview-lines'] parses as an integer >= 1.
- function postscriptPreviewSettings(params) {
-   const preview = !(params && params.preview === 'false');
-   let previewLines = parseInt(params && params['preview-lines'], 10);
-   if (isNaN(previewLines) || previewLines < 1) previewLines = 5;
-   return { preview, previewLines };
- }

//- Function to process analysis text - convert blank lines to paragraph breaks
- function processAnalysisText(text) {
-   const paragraphs = text.split(/\n\s*\n/).map(para => para.trim()).filter(para => para.length > 0);
-   const processedParagraphs = paragraphs.map(para => {
-     if (para.includes('<') && para.includes('>')) {
-       return para;
-     } else {
-       return '<p>' + para + '</p>';
-     }
-   });
-   return processedParagraphs.join('');
- }

//- Mixin to process lines and add <br /> tags
mixin processLines(text)
  if text
    - const lines = text.split('\n')
    - let index = 0
    each line in lines
      != line
      if index < lines.length - 1
        br
      - index++

//- Main poem-content mixin.
//- Locals used: title, author, date, slug, versions, songs, postscript, analysis, labels, labelBase, standalone
mixin poemContent
  if standalone
    //- A caller that embeds this fragment with no title heading of its own
    //- (renderPoem's live preview) needs one here; poem-page.pug and
    //- all-poems.html already supply their own external h2.poem-title, so
    //- they leave `standalone` unset to avoid a duplicate.
    h2.poem-title!= titleHtml
  div(id=`poem--${slug}`)
    div.poem-info
      span(id=`title--${slug}` class="title")!= titleHtml
      br
      span(id=`author--${slug}` class="author")= author
      br
      span(id=`date--${slug}` class="date")= date
      br
    br
    div.poem-body
      if versions && versions.length > 0
        each version, versionIndex in versions
          if version.label
            hr
            div.poem-info!= version.label
          if version.segments && version.segments.length > 0
            each segment in version.segments
              if segment.label
                span.song-segment!= `[${segment.label}]`
                br
              if segment.parts
                each part in segment.parts
                  if part.type === 'html'
                    != part.html
                  else
                    +processLines(part.lines)
              else
                +processLines(segment.lines)
              if segment !== version.segments[version.segments.length - 1]
                br
          if versionIndex < versions.length - 1
            br
      else
        p.no-content No content available
    //- end poem-body

    if labels && labels.length > 0
      ul.poem-labels
        each label in labels
          li: a.poem-label(href=`${labelBase || ''}all-poems.html?scope=labels&q=${encodeURIComponent(label)}`)= label

    if songs && songs.length > 0
      div(id=`song--${slug}` class="song-link")
        each song in songs
          //- Generic type classes (.song-item-embed / .song-item-link) let CSS
          //- target all embed- or link-type handlers at once; .song-item--<service>
          //- stays available for per-service overrides.
          - let songItemClass = `song-item song-item--${song.service}`
          - if (song.embed) songItemClass += ' song-item-embed'
          - if (song.link) songItemClass += ' song-item-link'
          div(class=songItemClass)
            if song.embed
              //- The embed's player size is emitted as a CSS custom property on
              //- the .song-embed-player (one of --song-embed-height OR
              //- --song-embed-aspect-ratio; the latter adds the --aspect
              //- modifier class). The resolved media type, when known, is
              //- exposed as data-embed-media + a song-embed--<service>--<media>
              //- class for per-media styling / forward-compat.
              - let embedClass = `song-embed song-embed--${song.service}`
              - if (song.embed.media) embedClass += ` song-embed--${song.service}--${song.embed.media}`
              div(class=embedClass data-embed-media=song.embed.media)
                //- data-allow[-fullscreen] carry a handler's embed_allow /
                //- embed_allowfullscreen override, if any; absent unless the
                //- handler set one, in which case poetic.js applies its
                //- global default instead.
                button.song-embed-btn(
                  id=`song-embed-btn--${song.service}--${slug}`
                  type="button"
                  data-embed-src=song.embed.src
                  data-title=song.embed.title
                  data-allow=song.embed.allow
                  data-allow-fullscreen=song.embed.allowFullscreen
                )= song.embed.buttonLabel
                - let playerClass = 'song-embed-player hidden'
                - if (song.embed.sizeIsAspect) playerClass += ' song-embed-player--aspect'
                - let playerStyle = song.embed.sizeVar ? `${song.embed.sizeVar}: ${song.embed.sizeValue}` : false
                div(class=playerClass style=playerStyle)
            if song.link
              a.song-link-anchor(
                class=`song-link--${song.service}`
                href=song.link.href
                target="_blank"
              )= song.link.label
      //- end song

    if postscript && postscript.length > 0
      each postscriptItem in postscript
        - const postscriptId = `postscript-${postscriptItem.label ? slugify(postscriptItem.label) : 'item'}--${slug}`
        - const { preview, previewLines } = postscriptPreviewSettings(postscriptItem.params)
        div(
          id=postscriptId
          class="postscript"
        )
          if postscriptItem.label
            div.postscript-label!= postscriptItem.label
          if postscriptItem.content
            //- %{...} context variables were already resolved in poem-render.js.
            - const processedContent = postscriptItem.content
            if preview
              - const toggleId = `${postscriptId}--more`
              input.postscript-toggle-cb.hidden(id=toggleId type="checkbox")
              div.postscript-content(style=`--preview-lines: ${previewLines}` data-preview-lines=previewLines)!= processedContent
              label.postscript-toggle(for=toggleId)
                span.sr-only See more
            else
              != processedContent
      //- end postscript
    //- end postscript section

    if analysis
      //- begin analysis section
      button.analysis.show(
        id=`show-analysis--${slug}`
        type="button"
        onclick=`document.getElementById('analysis--${slug}').style.display = 'block'; document.getElementById('show-analysis--${slug}').style.display = 'none';`
      ) Show analysis

      div.analysis(id=`analysis--${slug}`)
        button.analysis.hide(
          id=`hide-analysis--${slug}`
          type="button"
          onclick=`document.getElementById('analysis--${slug}').style.display = 'none'; document.getElementById('show-analysis--${slug}').style.display = 'block';`
        ) Hide analysis

        if analysis.synopsis && analysis.full
          .full-or-synopsis-selector
            button.analysis.selector.selected(
              id=`analysis-select-syno--${slug}`
              type="button"
              onclick=`el = name => document.getElementById('analysis-' + name + '--${slug}'); el('full').style.display = 'none'; el('syno').style.display = 'block'; el('select-full').classList.remove('selected'); el('select-syno').classList.add('selected');`
            ) Synopsis
            button.analysis.selector(
              id=`analysis-select-full--${slug}`
              type="button"
              onclick=`el = name => document.getElementById('analysis-' + name + '--${slug}'); el('full').style.display = 'block'; el('syno').style.display = 'none'; el('select-full').classList.add('selected'); el('select-syno').classList.remove('selected');`
            ) Full Analysis
          //- end full-or-synopsis-selector

          div(id=`analysis-syno--${slug}`)
            h2 Analysis of <em>!{titleHtml}</em> (synopsis)
            - const processedSynopsis = processAnalysisText(analysis.synopsis)
            != processedSynopsis
          //- end analysis-syno

          div(id=`analysis-full--${slug}` class="hidden")
            h2 Analysis of <em>!{titleHtml}</em>
            - const processedFull = processAnalysisText(analysis.full)
            != processedFull
          //- end analysis-full
        else
          h2 Analysis of <em>!{titleHtml}</em>
          - const processedFull = processAnalysisText(analysis.full)
          != processedFull
      //- end analysis
      //- end analysis section
  //- end poem
